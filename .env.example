# PostgreSQL connection for local development outside Docker
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/transitops"

# Session secret — generate with: openssl rand -base64 32
AUTH_SECRET=""

# Keep cookies usable on plain HTTP deployments such as http://EC2_IP:3000.
# Set to false when serving behind HTTPS.
AUTH_TRUST_HOST="true"

# Set to true when starting Docker Compose if you want demo data loaded.
SEED_DB="false"
